meta {
  name: Rate Limit
  type: http
  seq: 99
}

get {
  url: {{baseUrl}}/api/health
  body: none
  auth: none
}

tests {
  test("should return 200 normally", function() {
    // This test verifies the rate limiter is wired up.
    // To trigger a 429, start the server with RATE_LIMIT_RPM=1 and send 2+ requests.
    // In normal operation (RATE_LIMIT_RPM=60) this will return 200.
    const status = res.getStatus();
    expect(status === 200 || status === 429).to.equal(true);
  });

  test("rate limit response has correct shape when triggered", function() {
    if (res.getStatus() === 429) {
      expect(res.getBody().error).to.be.a("string");
      expect(res.getBody().code).to.equal("RATE_LIMIT_EXCEEDED");
    }
  });
}
