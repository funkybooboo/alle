meta {
  name: Delete Project
  type: http
  seq: 39
}

delete {
  url: {{baseUrl}}/api/projects/{{projectId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.data.success: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return success", function() {
    expect(res.getBody().data.success).to.equal(true);
  });
}
