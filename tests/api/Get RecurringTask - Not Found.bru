meta {
  name: Get RecurringTask - Not Found
  type: http
  seq: 44
}

get {
  url: {{baseUrl}}/api/recurring-tasks/nonexistent-id
  body: none
  auth: none
}

assert {
  res.status: eq 404
}

tests {
  test("should return 404 Not Found", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should return error", function() {
    expect(res.getBody().error).to.be.a("string");
    expect(res.getBody().code).to.equal("NOT_FOUND");
  });
}
