meta {
  name: Activate Project
  type: http
  seq: 38
}

post {
  url: {{baseUrl}}/api/projects/{{projectId}}/activate
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.data.isActive: eq true
}

tests {
  test("should return 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return activated project", function() {
    expect(res.getBody().data.isActive).to.equal(true);
  });
}
