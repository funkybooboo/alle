meta {
  name: Rename Tag - Validation Error
  type: http
  seq: 75
}

post {
  url: {{baseUrl}}/api/tags/rename
  body: json
  auth: none
}

body:json {
  {
    "from": "",
    "to": "work"
  }
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return validation error", function() {
    expect(res.getBody().error).to.be.a("string");
    expect(res.getBody().code).to.equal("VALIDATION_ERROR");
  });
}
