meta {
  name: Get Tasks - Filter by Completion
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}{{apiPrefix}}/tasks?completed=false
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return array", function() {
    expect(res.getBody().data).to.be.an("array");
  });

  test("all returned tasks should be incomplete", function() {
    const tasks = res.getBody().data;
    tasks.forEach(function(task) {
      expect(task.completed).to.equal(false);
    });
  });
}
