meta {
  name: Get Tasks - Content Negotiation
  type: http
  seq: 15
}

get {
  url: {{baseUrl}}{{apiPrefix}}/tasks
  body: none
  auth: none
}

headers {
  Accept: text/plain
}

assert {
  res.status: eq 200
}

tests {
  test("should return 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("should return plain text", function() {
    const contentType = res.getHeader("content-type");
    expect(contentType).to.include("text/plain");
  });

  test("body should be a string", function() {
    expect(res.getBody()).to.be.a("string");
  });
}
