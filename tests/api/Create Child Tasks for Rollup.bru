meta {
  name: Create Child Tasks for Rollup
  type: http
  seq: 82
}

post {
  url: {{baseUrl}}{{apiPrefix}}/tasks
  body: json
  auth: none
}

body:json {
  {
    "text": "Child task 1",
    "date": "2026-01-20",
    "parentId": "{{rollupParentId}}"
  }
}

assert {
  res.status: eq 201
}

tests {
  test("should create child task 1", function() {
    expect(res.getStatus()).to.equal(201);
    bru.setVar("rollupChild1Id", res.getBody().data.id);
  });
}
