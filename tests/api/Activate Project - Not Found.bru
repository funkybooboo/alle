meta {
  name: Activate Project - Not Found
  type: http
  seq: 73
}

post {
  url: {{baseUrl}}/api/projects/nonexistent-id/activate
  body: none
  auth: none
}

assert {
  res.status: eq 404
}

tests {
  test("should return 404 Not Found", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should return NOT_FOUND code", function() {
    expect(res.getBody().error).to.be.a("string");
    expect(res.getBody().code).to.equal("NOT_FOUND");
  });
}
