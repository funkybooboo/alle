meta {
  name: Complete Child 1 - No Rollup Yet
  type: http
  seq: 84
}

put {
  url: {{baseUrl}}{{apiPrefix}}/tasks/{{rollupChild1Id}}
  body: json
  auth: none
}

body:json {
  {
    "completed": true
  }
}

assert {
  res.status: eq 200
  res.body.data.completed: eq true
}

tests {
  test("should complete child 1", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().data.completed).to.equal(true);
  });

  test("parent should NOT be completed yet (one sibling still incomplete)", async function() {
    const parentRes = await bru.sendRequest({
      url: bru.getEnvVar("baseUrl") + bru.getEnvVar("apiPrefix") + "/tasks/" + bru.getVar("rollupParentId"),
      method: "GET",
    });
    expect(parentRes.getBody().data.completed).to.equal(false);
  });
}
