meta {
  name: Generate RecurringTask Instances - Invalid Dates
  type: http
  seq: 80
}

post {
  url: {{baseUrl}}/api/recurring-tasks/{{tempRtId}}/generate
  body: json
  auth: none
}

body:json {
  {
    "startDate": "not-a-date",
    "endDate": "also-not-a-date"
  }
}

assert {
  res.status: eq 400
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("should return validation error", function() {
    expect(res.getBody().error).to.be.a("string");
    expect(res.getBody().code).to.equal("VALIDATION_ERROR");
  });
}
