meta {
  name: Delete Task - Not Found
  type: http
  seq: 63
}

delete {
  url: {{baseUrl}}{{apiPrefix}}/tasks/nonexistent-id
  body: none
  auth: none
}

assert {
  res.status: eq 404
}

tests {
  test("should return 404 Not Found", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("should return NOT_FOUND code", function() {
    expect(res.getBody().error).to.be.a("string");
    expect(res.getBody().code).to.equal("NOT_FOUND");
  });
}
